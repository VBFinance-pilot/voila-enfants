# Server-side only (Vercel environment variables)
# These must be set in Vercel Dashboard > Settings > Environment Variables
# They are NOT prefixed with VITE_ so they stay server-side only.

SMTP_HOST=smtp.protonmail.ch
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-smtp-password
CONTACT_EMAIL_TO=contact-voilaJP@protonmail.com
